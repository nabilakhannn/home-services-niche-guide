# ─── GoHighLevel / Lead Connector (ScaleBuds new location) ───
# Restart dev server after changing. Set the same keys in Vercel → Project → Settings → Environment Variables.

# Where POST /api/submit-lead forwards JSON (workflow trigger / booking endpoint).
# Flat JSON from buildGhlPayload() — opening this URL in a browser sends GET (no body) and GHL will error; test with POST + JSON.
GHL_INBOUND_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/Pglkea64yintAtcVebhi/webhook-trigger/wcaMlNw5BRX1OZxwDxOX

# Pipeline ID for “New Lead” (Settings → Pipelines — id looks like pit-…).
# Note: this is NOT your Private Integration API token.
GHL_PIPELINE_ID=pit-9065baee-ac4a-43d5-883b-2744f85d6830

# Location ID (sub-account). Included on each lead as JSON key ghlLocationId.
GHL_LOCATION_ID=Pglkea64yintAtcVebhi

# Optional: HighLevel REST API — create under Settings → Integrations → Private Integrations.
# Do not commit real tokens. Use only for server-side scripts, not the browser.
# GHL_PRIVATE_INTEGRATION_TOKEN=

# Public site URL (optional, used in articles/schema)
# VITE_PUBLIC_SITE_URL=https://scalebuds.com

# Business address & phone (shown in footer / legal — GHL & carrier compliance)
# Pipe-separated lines after the legal name line (see businessContact.ts)
# VITE_PUBLIC_LEGAL_ENTITY_LINE=NK Digital Enterprise · d/b/a ScaleBuds Marketing
# VITE_PUBLIC_BUSINESS_ADDRESS=971 US HIGHWAY 202N STE R|BRANCHBURG, NEW JERSEY 08876
